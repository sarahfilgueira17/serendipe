---
const navLinks = ['Systems', 'Security', 'Intelligence', 'Network'];
---

<header class="fixed top-0 w-full z-50 bg-surface-variant/50 backdrop-blur-xl ambient-shadow px-6 md:px-10 lg:px-16 py-5 lg:py-6 flex justify-between items-center">
  <div class="flex items-center gap-2">
    <span class="material-symbols-outlined text-primary">terminal</span>
    <span class="text-xl md:text-2xl font-bold tracking-tighter text-on-surface font-headline">Serendipe</span>
  </div>

  <nav class="hidden md:flex items-center gap-8">
    {navLinks.map((link) => (
      <a href="#" class="text-on-surface-variant hover:text-on-surface text-sm font-body tracking-wide transition-colors duration-200">
        {link}
      </a>
    ))}
    <a href="#" class="gradient-primary text-on-primary font-headline font-semibold text-sm px-5 py-2.5 rounded-full hover:shadow-[0_0_15px_rgba(127,155,194,0.3)] transition-shadow duration-200">
      Get Started
    </a>
  </nav>

  <button class="md:hidden text-on-surface-variant hover:text-primary transition-colors duration-200">
    <span class="material-symbols-outlined">menu</span>
  </button>
</header>
