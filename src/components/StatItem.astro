---
interface Props {
  icon: string;
  value: string;
  description: string;
}

const { icon, value, description } = Astro.props;
---

<div class="flex flex-col gap-2 md:flex-1">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
      <span class="material-symbols-outlined text-primary">{icon}</span>
    </div>
    <span class="text-5xl md:text-4xl lg:text-6xl font-bold font-headline tracking-tighter text-on-surface">{value}</span>
  </div>
  <p class="text-on-surface-variant max-w-xs pl-[3.25rem] md:pl-[3.75rem] leading-relaxed text-sm md:text-base">{description}</p>
</div>
