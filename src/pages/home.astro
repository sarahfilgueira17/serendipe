<script>
  function initEtapasProgress() {
    const container = document.querySelector('.etapas-container');
    const progressLine = document.querySelector('.etapas-progress');
    const markers = document.querySelectorAll('.etapa-marker');
    const track = document.querySelector('.etapas-track');
    if (!container || !progressLine || !track) return;

    function update() {
      const containerRect = container.getBoundingClientRect();
      const trackRect = track.getBoundingClientRect();
      const trackHeight = trackRect.height;

      const viewportTrigger = window.innerHeight * 0.55;
      const scrolled = viewportTrigger - containerRect.top;
      const ratio = Math.max(0, Math.min(1, scrolled / trackHeight));

      progressLine.style.height = (ratio * 100) + '%';

      markers.forEach((marker) => {
        const markerRect = marker.getBoundingClientRect();
        const markerCenter = markerRect.top + markerRect.height / 2;
        const etapaItem = marker.closest('.etapa-item');
        if (markerCenter < viewportTrigger) {
          marker.classList.add('is-active');
          if (etapaItem) etapaItem.classList.add('is-active');
        } else {
          marker.classList.remove('is-active');
          if (etapaItem) etapaItem.classList.remove('is-active');
        }
      });
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  }

  document.addEventListener('DOMContentLoaded', initEtapasProgress);
  document.addEventListener('astro:page-load', initEtapasProgress);
</script>
