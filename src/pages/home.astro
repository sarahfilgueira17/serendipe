---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Serendipe — Home">
  <!-- TopAppBar Navigation -->
  <header class="bg-surface/60 backdrop-blur-xl fixed top-0 w-full z-50 ambient-shadow">
    <nav class="flex flex-row-reverse lg:flex-row justify-between items-center px-6 lg:px-12 xl:px-20 h-16 lg:h-20 w-full max-w-[1440px] mx-auto">
      <h1 class="text-2xl font-bold bg-gradient-to-r from-primary to-primary-container bg-clip-text text-transparent font-headline tracking-tighter">Serendipe</h1>

      <!-- Desktop Nav Links -->
      <div class="hidden lg:flex items-center gap-10">
        <a href="#ecosystem" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Ecosystem</a>
        <a href="#stats" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Performance</a>
        <a href="#" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Research</a>
        <a href="#" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Contact</a>
      </div>

      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity cursor-pointer scale-95 active:duration-100">search</span>
        <span class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity cursor-pointer scale-95 active:duration-100 lg:hidden">menu</span>
        <button class="hidden lg:inline-flex gradient-primary text-on-primary-container px-6 py-2 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_15px_rgba(127,155,194,0.3)] transition-all duration-300">
          Get Started
        </button>
      </div>
    </nav>
  </header>

  <main class="w-full overflow-x-hidden">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col lg:flex-row items-center justify-center lg:justify-between pt-16 lg:pt-20 px-6 lg:px-12 xl:px-20 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 -z-20">
        <img src="/hero-bg.png" alt="" class="w-full h-full object-cover" />
      </div>
      <!-- Overlay for readability -->
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-surface via-surface/70 to-surface/40"></div>

      <div class="max-w-[1440px] mx-auto w-full flex flex-col lg:flex-row items-center justify-center lg:justify-between">

      <!-- Hero Text Content (appears first on desktop for left placement) -->
      <div class="text-center lg:text-left max-w-lg lg:max-w-xl xl:max-w-2xl order-2 lg:order-1 lg:pr-12 xl:pr-20">
        <h2 class="font-headline text-[60px] font-medium tracking-tight mb-6 text-white" style="line-height: 67.98px;">
          Desbloqueie o Futuro da <span class="text-primary">Inovação</span>
        </h2>
        <p class="text-on-surface-variant text-lg lg:text-xl mb-10 leading-relaxed font-light max-w-md lg:max-w-lg">
          IA Estratégica e Lei de Informática para o Crescimento Exponencial da Sua Empresa.
        </p>
        <div class="flex items-center lg:items-start">
          <button class="gradient-primary text-on-primary-container px-10 py-4 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_20px_rgba(127,155,194,0.4)] transition-all duration-300 transform active:scale-95 whitespace-nowrap inline-flex items-center gap-2">
            <span class="material-symbols-outlined text-base">chevron_right</span>
            Explore nossos produtos e serviços
          </button>
        </div>
      </div>

      <!-- Futuristic Visual Component -->
      <div class="relative w-full max-w-sm lg:max-w-md xl:max-w-lg aspect-square mb-12 lg:mb-0 flex items-center justify-center order-1 lg:order-2 lg:flex-shrink-0">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent rounded-full animate-pulse"></div>
        <div class="relative z-10 glass-card p-8 lg:p-12 rounded-full border border-primary/20 kinetic-glow">
          <img
            alt="Futuristic microprocessor"
            class="w-48 h-48 lg:w-64 lg:h-64 xl:w-72 xl:h-72 object-contain mix-blend-lighten"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoAgx1csTeX-L3OVkgvhQuuiXkGtJwD2y0__-MEE__GU2Vv7TCDBL-bOaPqGPqp1TBlP3UF0IfIcqamFsLRxIFCfL8TxDz4OzIcDA5Q1V2hGyvzTJBB16KWgdyCrGGGOXxM_lMMiDWspwA5eI29QL53z7nhpxg11eGPbnRDoIZ43mvXOo3US0utF_zYw9FqCprs66x5756bBaXDuGlCxAtu8zHevvRoJ4iwlQT2zvZBYmoD7kh60kjyMZJB1RJVSwIOQ1bAKmeQDFp"
          />
        </div>
        <!-- Orbiting accents -->
        <div class="absolute top-0 right-10 w-4 h-4 bg-tertiary rounded-full blur-sm opacity-60"></div>
        <div class="absolute bottom-20 left-4 w-2 h-2 bg-primary-container rounded-full blur-[1px]"></div>
        <div class="hidden lg:block absolute -bottom-4 right-20 w-3 h-3 bg-tertiary/40 rounded-full blur-[2px]"></div>
        <div class="hidden lg:block absolute top-1/4 -left-6 w-2 h-2 bg-primary/60 rounded-full blur-[1px]"></div>
      </div>
      </div>
    </section>

    <!-- Nossas Soluções de IA Section -->
    <section id="ecosystem" class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface-container-low">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <div class="flex flex-col items-center mb-16 lg:mb-20 text-center">
          <header>
            <h3 class="font-headline text-4xl lg:text-[60px] font-medium text-white" style="line-height: 1.13;">Conheça nossas <span class="font-black text-primary">soluções</span></h3>
          </header>
        </div>

        <!-- Bento Grid / Glass Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8">
          <!-- Card 1: OpenAI & Modelos Preditivos -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="flex items-start justify-between mb-8">
              <span class="material-symbols-outlined text-primary text-4xl lg:text-5xl">psychology</span>
              <span class="text-on-surface-variant/30 font-headline text-4xl font-black">01</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">OpenAI & Modelos Preditivos</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Vá além da análise de dados. Com OpenAI, criamos modelos preditivos que antecipam o mercado, otimizam operações e revelam insights ocultos, transformando dados brutos em decisões de alto impacto.</p>
          </div>

          <!-- Card 2: Cloud Computing & Escalabilidade -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="flex items-start justify-between mb-8">
              <span class="material-symbols-outlined text-primary text-4xl lg:text-5xl">cloud</span>
              <span class="text-on-surface-variant/30 font-headline text-4xl font-black">02</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Cloud Computing & Escalabilidade</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Sua infraestrutura de IA na nuvem, com escalabilidade e segurança de nível empresarial. Garantimos que suas soluções de IA sejam robustas, flexíveis e sempre disponíveis, independentemente do volume de dados.</p>
          </div>

          <!-- Card 3: Big Data & Insights Acionáveis -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="flex items-start justify-between mb-8">
              <span class="material-symbols-outlined text-primary text-4xl lg:text-5xl">database</span>
              <span class="text-on-surface-variant/30 font-headline text-4xl font-black">03</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Big Data & Insights Acionáveis</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Transformamos o dilúvio de dados em um oceano de oportunidades. Com Big Data, coletamos, processamos e analisamos volumes massivos de informação para extrair padrões e gerar insights acionáveis que guiam sua estratégia.</p>
          </div>

          <!-- Card 4: Machine Learning & Automação Inteligente -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="flex items-start justify-between mb-8">
              <span class="material-symbols-outlined text-primary text-4xl lg:text-5xl">model_training</span>
              <span class="text-on-surface-variant/30 font-headline text-4xl font-black">04</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Machine Learning & Automação Inteligente</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Desenvolvemos algoritmos de Machine Learning que aprendem, adaptam e automatizam. Da otimização de cadeias de suprimentos à personalização da experiência do cliente, a automação inteligente está ao seu alcance.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section id="stats" class="py-20 lg:py-28 xl:py-32 px-6 lg:px-12 xl:px-20 border-t border-outline-variant/10">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-0 lg:justify-between max-w-5xl xl:max-w-6xl mx-auto">
        <div class="grid grid-cols-2 lg:flex gap-12 lg:gap-20 xl:gap-28 w-full lg:w-auto max-w-lg lg:max-w-none text-center lg:text-left">
          <div>
            <div class="font-headline text-4xl lg:text-5xl xl:text-6xl font-bold text-primary mb-1">24/7</div>
            <div class="text-xs text-on-surface-variant uppercase tracking-widest">Active Intelligence</div>
          </div>
          <div>
            <div class="font-headline text-4xl lg:text-5xl xl:text-6xl font-bold text-primary mb-1">99.9%</div>
            <div class="text-xs text-on-surface-variant uppercase tracking-widest">Global Uptime</div>
          </div>
          <div class="hidden lg:block">
            <div class="font-headline text-4xl lg:text-5xl xl:text-6xl font-bold text-primary mb-1">140+</div>
            <div class="text-xs text-on-surface-variant uppercase tracking-widest">Edge Nodes</div>
          </div>
        </div>
        <div class="bg-surface-container-highest p-1 rounded-full px-6 flex items-center gap-3">
          <span class="w-2 h-2 bg-tertiary rounded-full animate-pulse"></span>
          <span class="text-[10px] font-headline uppercase tracking-tighter text-on-surface-variant">Kinetic Framework Status: Optimal</span>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-surface-container-lowest w-full pt-20 lg:pt-24 pb-10 px-10 lg:px-20">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row lg:justify-between lg:items-start gap-10 lg:gap-0">
      <div class="flex flex-col items-center lg:items-start gap-4">
        <div class="text-xl font-bold text-on-surface font-headline tracking-tighter">Serendipe</div>
        <p class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant text-center lg:text-left max-w-xs leading-relaxed">
          © 2024 Serendipe Institute. Kinetic Intelligence Framework.
        </p>
      </div>
      <nav class="flex flex-wrap justify-center lg:justify-end gap-6 lg:gap-10">
        <a class="font-body text-sm uppercase tracking-widest text-on-surface-variant hover:text-white transition-colors" href="#">Privacy Policy</a>
        <a class="font-body text-sm uppercase tracking-widest text-on-surface-variant hover:text-white transition-colors" href="#">Terms of Tech</a>
        <a class="font-body text-sm uppercase tracking-widest text-on-surface-variant hover:text-white transition-colors" href="#">Global Ethics</a>
      </nav>
    </div>
  </footer>

  <!-- Bottom Navigation (Mobile only) -->
  <div class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50 glass-card rounded-full px-8 py-3 flex items-center gap-10 kinetic-glow border border-primary/10">
    <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">home</span>
    <span class="material-symbols-outlined text-on-surface-variant">biotech</span>
    <span class="material-symbols-outlined text-on-surface-variant">lightbulb</span>
    <span class="material-symbols-outlined text-on-surface-variant">mail</span>
  </div>
</Layout>

<style is:global>
  .glass-card {
    background: rgba(30, 39, 43, 0.4);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(127, 155, 194, 0.1);
  }

  .kinetic-glow {
    box-shadow: 0 0 20px rgba(127, 155, 194, 0.15);
  }

  .solution-card {
    background: rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(67, 73, 76, 0.5);
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
  }

  .solution-card:hover {
    border-color: rgba(127, 155, 194, 0.4);
    box-shadow: 0 0 25px rgba(127, 155, 194, 0.25), 0 0 50px rgba(127, 155, 194, 0.1);
  }
</style>
