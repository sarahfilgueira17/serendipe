---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Serendipe — Home">
  <!-- TopAppBar Navigation -->
  <header class="bg-surface/60 backdrop-blur-xl fixed top-0 w-full z-50 ambient-shadow">
    <nav class="flex flex-row-reverse lg:flex-row justify-between items-center px-6 lg:px-12 xl:px-20 h-16 lg:h-20 w-full max-w-[1440px] mx-auto">
      <h1 class="text-2xl font-bold bg-gradient-to-r from-primary to-primary-container bg-clip-text text-transparent font-headline tracking-tighter">Serendipe</h1>

      <!-- Desktop Nav Links -->
      <div class="hidden lg:flex items-center gap-10">
        <a href="#ecosystem" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Ecosystem</a>
        <a href="#stats" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Performance</a>
        <a href="#" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Research</a>
        <a href="#" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-on-surface transition-colors">Contact</a>
      </div>

      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity cursor-pointer scale-95 active:duration-100">search</span>
        <span class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity cursor-pointer scale-95 active:duration-100 lg:hidden">menu</span>
        <button class="hidden lg:inline-flex gradient-primary text-on-primary-container px-6 py-2 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_15px_rgba(127,155,194,0.3)] transition-all duration-300">
          Get Started
        </button>
      </div>
    </nav>
  </header>

  <main class="w-full overflow-x-hidden">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col lg:flex-row items-center justify-center lg:justify-between pt-16 lg:pt-20 px-6 lg:px-12 xl:px-20 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 -z-20">
        <img src="/hero-bg.png" alt="" class="w-full h-full object-cover" />
      </div>
      <!-- Overlay for readability -->
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-surface via-surface/70 to-surface/40"></div>

      <div class="max-w-[1440px] mx-auto w-full flex flex-col lg:flex-row items-center justify-center lg:justify-between">

      <!-- Hero Text Content (appears first on desktop for left placement) -->
      <div class="text-center lg:text-left max-w-lg lg:max-w-xl xl:max-w-2xl order-2 lg:order-1 lg:pr-12 xl:pr-20">
        <h2 class="font-headline text-[60px] font-medium tracking-tight mb-6 text-white" style="line-height: 67.98px;">
          Desbloqueie o Futuro da <span class="text-primary">Inovação</span>
        </h2>
        <p class="text-on-surface-variant text-lg lg:text-xl mb-10 leading-relaxed font-light max-w-md lg:max-w-lg">
          IA Estratégica e Lei de Informática para o Crescimento Exponencial da Sua Empresa.
        </p>
        <div class="flex items-center lg:items-start">
          <button class="gradient-primary text-on-primary-container px-10 py-4 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_20px_rgba(127,155,194,0.4)] transition-all duration-300 transform active:scale-95 whitespace-nowrap inline-flex items-center gap-2">
            <span class="material-symbols-outlined text-base">chevron_right</span>
            Explore nossos produtos e serviços
          </button>
        </div>
      </div>

      <!-- Futuristic Visual Component -->
      <div class="relative w-full max-w-sm lg:max-w-md xl:max-w-lg aspect-square mb-12 lg:mb-0 flex items-center justify-center order-1 lg:order-2 lg:flex-shrink-0">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent rounded-full animate-pulse"></div>
        <div class="relative z-10 glass-card p-8 lg:p-12 rounded-full border border-primary/20 kinetic-glow">
          <img
            alt="Futuristic microprocessor"
            class="w-48 h-48 lg:w-64 lg:h-64 xl:w-72 xl:h-72 object-contain mix-blend-lighten"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoAgx1csTeX-L3OVkgvhQuuiXkGtJwD2y0__-MEE__GU2Vv7TCDBL-bOaPqGPqp1TBlP3UF0IfIcqamFsLRxIFCfL8TxDz4OzIcDA5Q1V2hGyvzTJBB16KWgdyCrGGGOXxM_lMMiDWspwA5eI29QL53z7nhpxg11eGPbnRDoIZ43mvXOo3US0utF_zYw9FqCprs66x5756bBaXDuGlCxAtu8zHevvRoJ4iwlQT2zvZBYmoD7kh60kjyMZJB1RJVSwIOQ1bAKmeQDFp"
          />
        </div>
        <!-- Orbiting accents -->
        <div class="absolute top-0 right-10 w-4 h-4 bg-tertiary rounded-full blur-sm opacity-60"></div>
        <div class="absolute bottom-20 left-4 w-2 h-2 bg-primary-container rounded-full blur-[1px]"></div>
        <div class="hidden lg:block absolute -bottom-4 right-20 w-3 h-3 bg-tertiary/40 rounded-full blur-[2px]"></div>
        <div class="hidden lg:block absolute top-1/4 -left-6 w-2 h-2 bg-primary/60 rounded-full blur-[1px]"></div>
      </div>
      </div>
    </section>

    <!-- About / Value Proposition Section -->
    <section class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface-container-lowest">
      <div class="max-w-7xl mx-auto flex flex-col gap-16">
        <div class="flex flex-col lg:flex-row items-start gap-16 lg:gap-24">
          <!-- Text -->
          <div class="lg:w-[42%] lg:flex-shrink-0">
            <h3 class="font-headline text-3xl lg:text-4xl font-medium text-white mb-6 py-4">Sobre o <span class="text-primary font-bold">instituto</span></h3>
            <p class="font-body text-sm md:text-base lg:text-lg font-normal text-on-surface-variant leading-relaxed lg:leading-[1.6]">
              O Serendipe é o único Instituto de Ciência e Tecnologia do Brasil com foco exclusivo em Inteligência Artificial. Enquanto outros ICTs entregam conformidade, nós entregamos <span class="text-primary font-semibold">vantagem competitiva</span>, projetos de IA que transformam o investimento obrigatório da Lei de Informática em crescimento real para o seu negócio.
            </p>
          </div>

          <!-- Stat Boxes -->
          <div class="grid grid-cols-2 gap-4 lg:gap-5 w-full lg:flex-1">
            <div class="stat-box rounded-xl p-6 lg:p-8 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="stat-number font-headline text-4xl lg:text-5xl font-black text-primary">+60</span>
              <span class="text-on-surface-variant text-sm lg:text-base mt-2">clientes ativos</span>
            </div>
            <div class="stat-box rounded-xl p-6 lg:p-8 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="stat-number font-headline text-4xl lg:text-5xl font-black text-primary">+30</span>
              <span class="text-on-surface-variant text-sm lg:text-base mt-2">anos de experiência</span>
            </div>
            <div class="stat-box rounded-xl p-6 lg:p-8 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="stat-number font-headline text-4xl lg:text-5xl font-black text-primary">+800</span>
              <span class="text-on-surface-variant text-sm lg:text-base mt-2">pessoas ventureiras</span>
            </div>
            <div class="flex items-center justify-center p-6 lg:p-8 min-h-[140px] lg:min-h-[160px]">
              <a href="#" class="font-headline text-xs uppercase tracking-widest text-primary hover:text-white transition-colors inline-flex items-center gap-2 font-bold">
                Conheça nossos cases <span class="material-symbols-outlined text-base">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="text-center">
          <a href="#ecosystem" class="gradient-primary text-on-primary-container px-10 py-4 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_20px_rgba(127,155,194,0.4)] transition-all duration-300 active:scale-95 whitespace-nowrap inline-flex items-center gap-2">
            <span class="material-symbols-outlined text-base">chevron_right</span>
            Quero transformar meu investimento em IA
          </a>
        </div>
      </div>
    </section>

    <!-- Nossas Soluções de IA Section -->
    <section id="ecosystem" class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface-container-low">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <div class="flex flex-col items-center mb-16 lg:mb-20 text-center">
          <header>
            <h3 class="font-headline text-4xl lg:text-[60px] font-medium text-white" style="line-height: 1.13;">Conheça nossas <span class="font-black text-primary">soluções de IA</span></h3>
          </header>
          <p class="mt-6 text-on-surface-variant text-base lg:text-lg max-w-3xl leading-relaxed">Com o Serendipe, sua empresa acessa o que há de mais avançado em Inteligência Artificial, desenhado para otimizar processos, prever tendências e maximizar seu retorno sobre o investimento em P&D.</p>
        </div>

        <!-- Bento Grid / Glass Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8">
          <!-- Card 1: OpenAI & Modelos Preditivos -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="mb-8">
              <span class="material-symbols-outlined text-primary text-6xl lg:text-7xl">psychology</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">OpenAI & Modelos Preditivos</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Vá além da análise de dados. Com OpenAI, criamos modelos preditivos que antecipam o mercado, otimizam operações e revelam insights ocultos, transformando dados brutos em decisões de alto impacto.</p>
          </div>

          <!-- Card 2: Cloud Computing & Escalabilidade -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="mb-8">
              <span class="material-symbols-outlined text-primary text-6xl lg:text-7xl">cloud</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Cloud Computing & Escalabilidade</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Sua infraestrutura de IA na nuvem, com escalabilidade e segurança de nível empresarial. Garantimos que suas soluções de IA sejam robustas, flexíveis e sempre disponíveis, independentemente do volume de dados.</p>
          </div>

          <!-- Card 3: Big Data & Insights Acionáveis -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="mb-8">
              <span class="material-symbols-outlined text-primary text-6xl lg:text-7xl">database</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Big Data & Insights Acionáveis</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Transformamos o dilúvio de dados em um oceano de oportunidades. Com Big Data, coletamos, processamos e analisamos volumes massivos de informação para extrair padrões e gerar insights acionáveis que guiam sua estratégia.</p>
          </div>

          <!-- Card 4: Machine Learning & Automação Inteligente -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col h-full">
            <div class="mb-8">
              <span class="material-symbols-outlined text-primary text-6xl lg:text-7xl">model_training</span>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Machine Learning & Automação Inteligente</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Desenvolvemos algoritmos de Machine Learning que aprendem, adaptam e automatizam. Da otimização de cadeias de suprimentos à personalização da experiência do cliente, a automação inteligente está ao seu alcance.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Vantagem Competitiva Section -->
    <section class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <!-- Heading -->
        <div class="text-center mb-16 lg:mb-20">
          <h3 class="font-headline text-4xl lg:text-[56px] xl:text-[60px] font-medium text-white leading-tight">
            Sua Vantagem Competitiva com o <span class="text-primary font-bold">Serendipe</span>
          </h3>
          <p class="mt-6 text-on-surface-variant text-base lg:text-lg max-w-3xl mx-auto leading-relaxed">
            A Lei de Informática não é apenas um incentivo fiscal; é a porta de entrada para a inovação disruptiva. O Serendipe é seu parceiro estratégico para navegar por ela, garantindo que cada centavo investido em P&D com IA retorne em valor e competitividade.
          </p>
        </div>

        <!-- Gradient defs for icons -->
        <svg class="absolute w-0 h-0" aria-hidden="true">
          <defs>
            <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#a8c8f0" />
              <stop offset="100%" stop-color="#4a7bb5" />
            </linearGradient>
          </defs>
        </svg>

        <!-- Feature Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
          <!-- Card: Maximize os Créditos Fiscais -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="scale-icon">
                  <circle cx="12" cy="13" r="7" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                  <path d="M12 9v8" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M14.5 10.5c-.4-.6-1.2-1-2.5-1s-2.5.7-2.5 1.8c0 1.2 1.2 1.6 2.5 1.9 1.3.3 2.5.8 2.5 2-.0 1.1-1 1.8-2.5 1.8s-2.1-.4-2.5-1" stroke="url(#icon-gradient)" stroke-width="1.1" stroke-linecap="round"/>
                  <path d="M12 6V3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M9 4.5l3-1.5 3 1.5" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="text-center px-4">
                <h4 class="font-headline text-base lg:text-lg font-semibold text-on-surface mb-2">Maximize os Créditos Fiscais</h4>
                <p class="text-on-surface-variant text-sm leading-relaxed">Projetos de IA de alto impacto, 100% alinhados com os requisitos da Lei, convertendo obrigações em recursos para inovação.</p>
              </div>
            </div>
          </div>

          <!-- Card: Acelere o Desenvolvimento -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="scale-icon">
                  <path d="M12 20V10" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M12 10l-3 3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 10l3 3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8.5 14.5c-2.5.5-4 1.5-4 3 0 0 .5 2.5 7.5 2.5s7.5-2.5 7.5-2.5c0-1.5-1.5-2.5-4-3" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                  <circle cx="12" cy="6" r="3" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                  <path d="M10.5 5.5l1.5-1 1.5 1" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="10" y1="6.5" x2="14" y2="6.5" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="text-center px-4">
                <h4 class="font-headline text-base lg:text-lg font-semibold text-on-surface mb-2">Acelere o Desenvolvimento</h4>
                <p class="text-on-surface-variant text-sm leading-relaxed">Metodologias ágeis e foco em resultados para entregar suas soluções de IA no prazo e dentro do orçamento.</p>
              </div>
            </div>
          </div>

          <!-- Card: Reduza Riscos -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="scale-icon">
                  <path d="M12 3L4 7v5c0 5.25 3.4 10.2 8 11.5 4.6-1.3 8-6.25 8-11.5V7l-8-4z" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linejoin="round"/>
                  <path d="M9 12.5l2 2 4-4" stroke="url(#icon-gradient)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="text-center px-4">
                <h4 class="font-headline text-base lg:text-lg font-semibold text-on-surface mb-2">Reduza Riscos</h4>
                <p class="text-on-surface-variant text-sm leading-relaxed">Expertise regulatória e técnica para garantir conformidade e sucesso em cada etapa do seu projeto.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Cases Section -->
    <section id="cases" class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface-container-lowest">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <div class="text-center mb-16 lg:mb-20 max-w-3xl mx-auto">
          <h3 class="font-headline text-4xl lg:text-[56px] xl:text-[60px] font-medium text-white leading-tight">
            O que acontece quando inovação é <span class="text-primary font-bold">levada a sério</span>
          </h3>
          <p class="text-on-surface-variant text-base lg:text-lg mt-6 leading-relaxed font-light">
            Em pouco mais de um ano e meio, o Serendipe já transformou milhões de reais em investimentos de P&D em cases de sucesso tangíveis para empresas que ousaram inovar. Não somos apenas um instituto; somos um <span class="text-primary font-semibold">catalisador de resultados</span>.
          </p>
        </div>

        <!-- Bento Grid -->
        <div class="cases-bento">
          <!-- 1. Featured card (2col x 2row) - dark with gradient overlay -->
          <div class="cases-card-featured relative overflow-hidden rounded-xl group cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-br from-[#2a1f14] via-[#1e1a15] to-surface-container"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
            <div class="relative z-10 h-full flex flex-col justify-between p-6 lg:p-8">
              <span class="font-headline text-sm font-bold tracking-wider italic text-white/90 uppercase">Netshoes</span>
              <div>
                <p class="text-white text-sm lg:text-base font-medium mb-3 max-w-sm leading-snug">
                  Netshoes bloqueia automaticamente mais de 4 milhões de ameaças em seis meses
                </p>
                <a href="#" class="case-link">
                  <span class="material-symbols-outlined text-sm">chevron_right</span> Saiba mais
                </a>
              </div>
            </div>
          </div>

          <!-- 2. Dafiti - dark card -->
          <div class="rounded-xl bg-surface-container-highest flex items-center justify-center p-6 cursor-pointer hover:bg-surface-bright transition-colors">
            <span class="font-headline text-2xl lg:text-3xl font-light text-white tracking-tight">dafiti</span>
          </div>

          <!-- 3. Agibank - light card -->
          <div class="rounded-xl bg-inverse-surface flex items-center justify-center p-6 cursor-pointer hover:opacity-90 transition-opacity">
            <span class="font-headline text-xl lg:text-2xl font-bold text-surface tracking-tight flex items-center gap-2">
              <span class="text-primary">◇</span> agibank
            </span>
          </div>

          <!-- 4. Renner - light card -->
          <div class="rounded-xl bg-inverse-surface flex items-center justify-center p-6 cursor-pointer hover:opacity-90 transition-opacity">
            <span class="font-headline text-xl lg:text-2xl font-semibold text-surface tracking-tight flex items-center gap-2">
              <span class="text-on-surface-variant">⊙</span> Renner
            </span>
          </div>

          <!-- 5. Magalu - tertiary accent card (1col x 2row) -->
          <div class="cases-card-accent relative rounded-xl flex flex-col justify-between p-6 lg:p-8 cursor-pointer overflow-hidden transition-opacity hover:opacity-95">
            <span class="font-headline text-lg font-black text-[#1a1025] tracking-wider uppercase relative z-10">Magalu</span>
            <div class="relative z-10">
              <p class="text-[#1a1025]/80 text-sm leading-relaxed mb-4">
                Veja como o Magalu garante alta disponibilidade para centenas de aplicações de escala global
              </p>
              <a href="#" class="text-xs uppercase tracking-widest text-[#1a1025]/50 hover:text-[#1a1025] transition-colors inline-flex items-center gap-1 font-bold">
                <span class="material-symbols-outlined text-sm">chevron_right</span> Saiba mais
              </a>
            </div>
          </div>

          <!-- 6. Fourbank - primary accent card -->
          <div class="rounded-xl bg-primary flex items-center justify-center p-6 cursor-pointer hover:opacity-90 transition-opacity">
            <span class="font-headline text-base lg:text-lg font-black text-on-primary uppercase tracking-[0.25em]">Fourbank</span>
          </div>

          <!-- 7. GPA - dark card with text (1col x 2row) -->
          <div class="cases-card-tall relative overflow-hidden rounded-xl group cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-b from-[#1a1f14] via-[#151a12] to-surface-container-highest"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-6 lg:p-8">
              <p class="text-white text-sm font-medium mb-3 leading-snug">
                Grupo Pão de Açúcar (GPA) soluciona ciberataque e reduz custos em 30%
              </p>
