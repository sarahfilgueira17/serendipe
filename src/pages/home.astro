---
import Layout from '../layouts/Layout.astro';
import logoSerendipe from '../assets/LOGO SERENDIPE SITE.webp';
import logoRodape from '../assets/LOGO SERENDIPE RODAPÉ.webp';
import samyDana from '../assets/Samy Dana Co Founder.svg';
---

<Layout title="Serendipe — Home">
  <!-- TopAppBar Navigation -->
  <header class="bg-surface/60 backdrop-blur-xl fixed top-0 w-full z-50 ambient-shadow">
    <nav class="flex flex-row-reverse lg:flex-row justify-between items-center px-6 lg:px-12 xl:px-20 h-16 lg:h-20 w-full max-w-[1440px] mx-auto">
      <a href="/">
        <img src={logoSerendipe.src} alt="Serendipe" class="h-10 lg:h-14 w-auto" />
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden lg:flex items-center gap-10">
        <a href="#sobre" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors">Sobre</a>
        <a href="#solucoes" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors">Soluções</a>
        <a href="#metodo" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors">Método</a>
        <a href="#processo" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors">Processo</a>
        <a href="#cases" class="font-body text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors">Cases</a>
      </div>

      <div class="flex items-center gap-4">
        <button id="menu-toggle" class="lg:hidden text-primary hover:opacity-80 transition-opacity cursor-pointer active:duration-100" aria-label="Menu" aria-expanded="false">
          <span class="material-symbols-outlined scale-95">menu</span>
        </button>
        <button type="button" class="open-form-modal hidden lg:inline-flex gradient-primary text-on-primary-container px-6 py-2 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_15px_rgba(127,155,194,0.3)] transition-all duration-300 cursor-pointer">
          Agendar Análise
        </button>
      </div>
    </nav>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

  <!-- Mobile Menu Drawer -->
  <nav id="mobile-menu" class="fixed top-0 left-0 h-full w-72 z-[70] bg-surface-container-lowest/95 backdrop-blur-xl border-r border-outline-variant/20 translate-x-[-100%] transition-transform duration-300 ease-out lg:hidden flex flex-col">
    <div class="flex items-center justify-between px-6 h-16">
      <a href="/" id="mobile-menu-logo">
        <img src={logoSerendipe.src} alt="Serendipe" class="h-9 w-auto" />
      </a>
      <button id="menu-close" class="text-on-surface-variant hover:text-primary transition-colors cursor-pointer" aria-label="Fechar menu">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <div class="flex flex-col px-6 pt-6 gap-1 flex-1">
      <a href="#sobre" class="mobile-nav-link font-body text-sm uppercase tracking-[0.15em] text-on-surface-variant hover:text-primary py-3 px-3 rounded-lg hover:bg-primary/5 transition-all">Sobre</a>
      <a href="#solucoes" class="mobile-nav-link font-body text-sm uppercase tracking-[0.15em] text-on-surface-variant hover:text-primary py-3 px-3 rounded-lg hover:bg-primary/5 transition-all">Soluções</a>
      <a href="#metodo" class="mobile-nav-link font-body text-sm uppercase tracking-[0.15em] text-on-surface-variant hover:text-primary py-3 px-3 rounded-lg hover:bg-primary/5 transition-all">Método</a>
      <a href="#processo" class="mobile-nav-link font-body text-sm uppercase tracking-[0.15em] text-on-surface-variant hover:text-primary py-3 px-3 rounded-lg hover:bg-primary/5 transition-all">Processo</a>
      <a href="#cases" class="mobile-nav-link font-body text-sm uppercase tracking-[0.15em] text-on-surface-variant hover:text-primary py-3 px-3 rounded-lg hover:bg-primary/5 transition-all">Cases</a>
    </div>

    <div class="px-6 pb-8">
      <button type="button" class="open-form-modal mobile-nav-link gradient-primary text-on-primary-container w-full py-3 rounded-full font-headline font-bold text-xs uppercase tracking-widest text-center block cursor-pointer">
        Agendar Análise
      </button>
    </div>
  </nav>

  <!-- Gradient defs for SVG icons (shared across sections) -->
  <svg class="absolute w-0 h-0" aria-hidden="true">
    <defs>
      <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#a8c8f0" />
        <stop offset="100%" stop-color="#4a7bb5" />
      </linearGradient>
    </defs>
  </svg>

  <main class="w-full overflow-x-hidden">
    <!-- Hero Section -->
    <section class="relative min-h-[auto] lg:min-h-screen flex items-center justify-center px-6 lg:px-12 xl:px-20 pt-52 pb-28 lg:pt-0 lg:pb-0 overflow-hidden">
      <!-- Background Video -->
      <div class="absolute inset-0 -z-20 overflow-hidden">
        <video autoplay muted loop playsinline class="w-full h-full object-cover">
          <source src="/Serendipe Background (1).mp4" type="video/mp4" />
        </video>
      </div>
      <!-- Overlay for readability -->
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-surface via-surface/70 to-surface/40"></div>

      <div class="flex flex-col items-center justify-center text-center">
        <h2 class="font-headline text-2xl md:text-4xl lg:text-5xl font-medium tracking-tight mb-10 text-white whitespace-nowrap" style="line-height: 1.13;">
          Desbloqueie o Futuro da <span class="text-primary">Inovação</span>
        </h2>
        <p class="text-on-surface-variant text-base lg:text-lg mb-16 leading-relaxed font-light max-w-2xl">
          O Serendipe transforma a Lei de Informática em seu maior ativo de P&D, impulsionando sua empresa para a era da <span class="text-primary font-semibold">Inteligência Artificial</span> com resultados preditivos e concretos. Não apenas cumprimos a Lei de Informática; nós a redefinimos, posicionando sua empresa na <span class="text-primary font-semibold">vanguarda da inovação</span>.
        </p>
        <a href="#solucoes" class="hero-cta gradient-primary text-on-primary-container px-10 py-4 rounded-full font-headline font-bold text-xs uppercase tracking-widest transition-all duration-300 transform active:scale-95 whitespace-nowrap inline-flex items-center gap-2">
          <span class="material-symbols-outlined text-base">chevron_right</span>
          Explore nossos produtos e serviços
        </a>
      </div>
    </section>

    <!-- About / Value Proposition Section -->
    <section id="sobre" class="pt-20 pb-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-[#070f17]">
      <div class="max-w-7xl mx-auto flex flex-col gap-16">
        <div class="flex flex-col lg:flex-row items-start gap-16 lg:gap-24">
          <!-- Text -->
          <div class="lg:w-[42%] lg:flex-shrink-0">
            <h3 class="font-headline text-2xl lg:text-[34px] xl:text-[38px] font-medium text-white mb-6 py-4">Sobre o <span class="text-primary font-bold">Instituto</span></h3>
            <p class="font-body text-sm md:text-base lg:text-lg font-normal text-on-surface-variant leading-relaxed lg:leading-[1.6]">
              No Serendipe, a inovação é um compromisso inabalável. Nosso propósito é impulsionar o progresso científico e tecnológico do Brasil, gerando <span class="text-primary font-semibold">valor sustentável</span> e transformando desafios em oportunidades reais para o mercado e a sociedade, através da Inteligência Artificial. Nossa abordagem é ágil, orientada a resultados e construída sobre parcerias estratégicas. Não entregamos apenas projetos; entregamos o <span class="text-primary font-semibold">futuro da sua empresa</span>, com ética, excelência e um impacto positivo duradouro.
            </p>
          </div>

          <!-- Stat Boxes -->
          <div class="grid grid-cols-2 gap-4 lg:gap-5 w-full lg:flex-1">
            <div class="stat-box rounded-xl p-5 lg:p-7 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="material-symbols-outlined text-primary mb-3" style="font-size: 3.5rem; font-variation-settings: 'FILL' 0, 'wght' 300, 'opsz' 48;">payments</span>
              <span class="stat-number font-headline text-3xl lg:text-4xl font-black text-primary mb-3">+18</span>
              <span class="font-headline text-xs lg:text-sm font-medium text-on-surface-variant/50">Investimentos PD&amp;I</span>
            </div>
            <div class="stat-box rounded-xl p-5 lg:p-7 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="material-symbols-outlined text-primary mb-3" style="font-size: 3.5rem; font-variation-settings: 'FILL' 0, 'wght' 300, 'opsz' 48;">handshake</span>
              <span class="stat-number font-headline text-3xl lg:text-4xl font-black text-primary mb-3">+4</span>
              <span class="font-headline text-xs lg:text-sm font-medium text-on-surface-variant/50">Clientes Atendidos</span>
            </div>
            <div class="stat-box rounded-xl p-5 lg:p-7 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="material-symbols-outlined text-primary mb-3" style="font-size: 3.5rem; font-variation-settings: 'FILL' 0, 'wght' 300, 'opsz' 48;">folder_open</span>
              <span class="stat-number font-headline text-3xl lg:text-4xl font-black text-primary mb-3">+7</span>
              <span class="font-headline text-xs lg:text-sm font-medium text-on-surface-variant/50">Projetos</span>
            </div>
            <div class="stat-box rounded-xl p-5 lg:p-7 flex flex-col items-center justify-center text-center min-h-[140px] lg:min-h-[160px]">
              <span class="material-symbols-outlined text-primary mb-3" style="font-size: 3.5rem; font-variation-settings: 'FILL' 0, 'wght' 300, 'opsz' 48;">groups</span>
              <span class="stat-number font-headline text-3xl lg:text-4xl font-black text-primary mb-3">+50</span>
              <span class="font-headline text-xs lg:text-sm font-medium text-on-surface-variant/50 leading-tight">Colaboradores PhDs, MScs e Especialistas</span>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="text-center">
          <a href="#cta" class="gradient-primary text-on-primary-container px-6 sm:px-10 py-4 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:shadow-[0_0_20px_rgba(127,155,194,0.4)] transition-all duration-300 active:scale-95 inline-flex items-center justify-center gap-2 text-center max-w-full">
            <span class="material-symbols-outlined text-base">chevron_right</span>
            Quero transformar meu investimento em IA
          </a>
        </div>
      </div>
    </section>

    <!-- Nossas Soluções de IA Section -->
    <section id="solucoes" class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface-container-low">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <div class="flex flex-col items-center mb-16 lg:mb-20 text-center">
          <header>
            <h3 class="font-headline text-2xl lg:text-[34px] xl:text-[38px] font-medium text-white leading-tight">Conheça nossas <span class="font-black text-primary">soluções de IA</span></h3>
          </header>
          <p class="mt-6 text-on-surface-variant text-base lg:text-lg max-w-3xl leading-relaxed">Com o Serendipe, sua empresa acessa o que há de mais avançado em Inteligência Artificial, desenhado para otimizar processos, prever tendências e maximizar seu retorno sobre o investimento em P&D.</p>
        </div>

        <!-- Bento Grid / Glass Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8">
          <!-- Card 1: Modelos Preditivos -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col items-center text-center h-full">
            <div class="mb-8 flex items-center justify-center py-2">
              <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="solution-icon">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17a1 1 0 001 1h6a1 1 0 001-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.87-3.13-7-7-7z" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linejoin="round"/>
                <path d="M9 21h6" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M10 19h4" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M12 2v3" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M8.5 8.5c0-1.93 1.57-3.5 3.5-3.5" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <circle cx="10" cy="10" r="0.8" fill="url(#icon-gradient)"/>
                <circle cx="14" cy="10" r="0.8" fill="url(#icon-gradient)"/>
                <path d="M10.5 12.5c.4.3 1 .5 1.5.5s1.1-.2 1.5-.5" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
              </svg>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Modelos Preditivos</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Criamos modelos que antecipam cenários, otimizam operações e transformam dados em decisões de alto impacto.</p>
          </div>

          <!-- Card 2: Cloud Computing & Escalabilidade -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col items-center text-center h-full">
            <div class="mb-8 flex items-center justify-center py-2">
              <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="solution-icon">
                <path d="M6.5 18A4.5 4.5 0 016.5 9h.3A7 7 0 0120 11.5a3.5 3.5 0 01-.5 7H6.5z" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linejoin="round"/>
                <path d="M8 14h2" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M12 14h4" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M9 16.5h6" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <circle cx="15" cy="12" r="0.7" fill="url(#icon-gradient)"/>
                <circle cx="11" cy="11.5" r="0.7" fill="url(#icon-gradient)"/>
              </svg>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Cloud Computing & Escalabilidade</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Infraestrutura de IA em nuvem, segura, flexível e pronta para escalar conforme sua demanda.</p>
          </div>

          <!-- Card 3: Big Data & Insights Acionáveis -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col items-center text-center h-full">
            <div class="mb-8 flex items-center justify-center py-2">
              <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="solution-icon">
                <ellipse cx="12" cy="6" rx="7" ry="3" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                <path d="M5 6v6c0 1.66 3.13 3 7 3s7-1.34 7-3V6" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                <path d="M5 12v6c0 1.66 3.13 3 7 3s7-1.34 7-3v-6" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                <path d="M9 9.5v3" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M12 10v3" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M15 9.5v3" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
              </svg>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Big Data & Insights Acionáveis</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Coletamos e analisamos grandes volumes de dados para gerar insights que guiam decisões estratégicas.</p>
          </div>

          <!-- Card 4: Machine Learning & Automação Inteligente -->
          <div class="solution-card p-8 lg:p-10 rounded-xl flex flex-col items-center text-center h-full">
            <div class="mb-8 flex items-center justify-center py-2">
              <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="solution-icon">
                <circle cx="12" cy="12" r="5" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                <circle cx="12" cy="12" r="2" stroke="url(#icon-gradient)" stroke-width="1"/>
                <path d="M12 3v3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M12 18v3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M3 12h3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M18 12h3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M5.64 5.64l2.12 2.12" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M16.24 16.24l2.12 2.12" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M5.64 18.36l2.12-2.12" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                <path d="M16.24 7.76l2.12-2.12" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
              </svg>
            </div>
            <h4 class="text-xl font-headline font-semibold mb-3">Machine Learning & Automação Inteligente</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed flex-1">Desenvolvemos algoritmos que aprendem, automatizam processos e elevam a eficiência operacional.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Vantagem Competitiva Section -->
    <section id="metodo" class="py-24 lg:py-32 xl:py-40 px-6 lg:px-12 xl:px-20 bg-surface">
      <div class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto">
        <!-- Heading -->
        <div class="text-center mb-16 lg:mb-20">
          <h3 class="font-headline text-2xl lg:text-[34px] xl:text-[38px] font-medium text-white leading-tight">
            Sua Vantagem Competitiva com o <span class="text-primary font-bold">Serendipe</span>
          </h3>
          <p class="mt-10 lg:mt-12 text-on-surface-variant text-base lg:text-lg max-w-3xl mx-auto leading-relaxed">
            A Lei de Informática não é apenas um incentivo fiscal; é a porta de entrada para a inovação disruptiva. O Serendipe é seu parceiro estratégico para navegar por ela, garantindo que cada centavo investido em P&D com IA retorne em valor e competitividade.
          </p>
        </div>

        <!-- Feature Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
          <!-- Card: Maximize os Créditos Fiscais -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="scale-icon">
                  <circle cx="12" cy="13" r="7" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                  <path d="M12 9v8" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M14.5 10.5c-.4-.6-1.2-1-2.5-1s-2.5.7-2.5 1.8c0 1.2 1.2 1.6 2.5 1.9 1.3.3 2.5.8 2.5 2-.0 1.1-1 1.8-2.5 1.8s-2.1-.4-2.5-1" stroke="url(#icon-gradient)" stroke-width="1.1" stroke-linecap="round"/>
                  <path d="M12 6V3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M9 4.5l3-1.5 3 1.5" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="text-center px-4">
                <h4 class="font-headline text-base lg:text-lg font-semibold text-on-surface mb-2">Maximize os Créditos Fiscais</h4>
                <p class="text-on-surface-variant text-sm leading-relaxed">Projetos de IA de alto impacto, 100% alinhados com os requisitos da Lei, convertendo obrigações em recursos para inovação.</p>
              </div>
            </div>
          </div>

          <!-- Card: Acelere o Desenvolvimento -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="scale-icon">
                  <path d="M12 20V10" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M12 10l-3 3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 10l3 3" stroke="url(#icon-gradient)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8.5 14.5c-2.5.5-4 1.5-4 3 0 0 .5 2.5 7.5 2.5s7.5-2.5 7.5-2.5c0-1.5-1.5-2.5-4-3" stroke="url(#icon-gradient)" stroke-width="1" stroke-linecap="round"/>
                  <circle cx="12" cy="6" r="3" stroke="url(#icon-gradient)" stroke-width="1.2"/>
                  <path d="M10.5 5.5l1.5-1 1.5 1" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="10" y1="6.5" x2="14" y2="6.5" stroke="url(#icon-gradient)" stroke-width="0.8" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="text-center px-4">
                <h4 class="font-headline text-base lg:text-lg font-semibold text-on-surface mb-2">Acelere o Desenvolvimento</h4>
                <p class="text-on-surface-variant text-sm leading-relaxed">Metodologias ágeis e foco em resultados para entregar suas soluções de IA no prazo e dentro do orçamento.</p>
              </div>
            </div>
          </div>

          <!-- Card: Reduza Riscos -->
          <div class="scale-card group relative rounded-xl flex flex-col items-center gap-6">
            <div class="scale-card-inner rounded-xl p-6 lg:p-8 flex flex-col items-center gap-6 w-full h-full relative z-10">
              <div class="w-full flex items-center justify-center py-6 lg:py-8">
