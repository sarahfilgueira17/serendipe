---
const links = ['Systems', 'Security', 'Intelligence', 'Network'];
---

<footer class="bg-surface-container-lowest w-full py-12 lg:py-16 px-6 md:px-10 lg:px-16">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="flex flex-col items-center md:items-start gap-4">
      <span class="font-headline font-bold text-on-surface text-xl tracking-tighter">Serendipe</span>
      <p class="text-on-surface-variant font-body text-sm tracking-wide">&copy; 2026 Serendipe Institute. Powered by AI.</p>
    </div>
    <nav class="flex flex-wrap justify-center gap-6 lg:gap-8">
      {links.map((link) => (
        <a class="text-on-surface-variant hover:text-on-surface transition-all font-body text-sm tracking-wide" href="#">
          {link}
        </a>
      ))}
    </nav>
  </div>
</footer>
